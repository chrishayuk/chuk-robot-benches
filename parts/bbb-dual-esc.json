{
  "id": "bbb-dual-esc",
  "kind": "esc",
  "mass_g": 5.0,
  "provisional": true,
  "current_ma": 15.0,
  "nominal_v": 7.4,
  "notes": "dual brushed ESC with 5V BEC; ~15mA quiescent (excludes motor current and whatever the BEC passes on to the 5V rail)",
  "elec": {
    "pins": {
      "VIN": {
        "role": "power_in",
        "v_range": [
          6.0,
          9.0
        ],
        "required": true
      },
      "GND": {
        "role": "gnd",
        "required": true
      },
      "BEC5V": {
        "role": "power_out",
        "volts": 5.0,
        "max_a": 1.0
      },
      "S1": {
        "role": "signal_in",
        "signal": "pwm",
        "required": true,
        "channel": "M1"
      },
      "S2": {
        "role": "signal_in",
        "signal": "pwm",
        "required": true,
        "channel": "M2"
      },
      "M1+": {
        "role": "motor_out",
        "channel": "M1"
      },
      "M1-": {
        "role": "motor_out",
        "channel": "M1"
      },
      "M2+": {
        "role": "motor_out",
        "channel": "M2"
      },
      "M2-": {
        "role": "motor_out",
        "channel": "M2"
      }
    }
  },
  "description": "The motor controller (ESC). It turns the brain's throttle commands into switched battery power for the two drive motors, and its built-in 5V regulator (the BEC) powers the brain and radio.",
  "esc": {
    "supports_winding": "brushed"
  }
}
