{
  "name": "example-power-budget-demo",
  "instances": {
    "batt": "lipo-2s-260",
    "sw": "power-switch-slide",
    "conn": "connector-xt30",
    "fuse": "fuse-ptc-5a",
    "esc": "bbb-dual-esc",
    "mcu": "rp2350-zero",
    "m1": "n20-motor-6v",
    "lifter": "servo-9g-lifter"
  },
  "nets": [
    { "id": "vbat_sw", "pins": ["batt.+", "sw.in"], "volts": 7.4 },
    { "id": "vbat_conn", "pins": ["sw.out", "conn.P1"], "volts": 7.4 },
    { "id": "vbat_fuse", "pins": ["conn.P2", "fuse.P1"], "volts": 7.4 },
    { "id": "vbat", "pins": ["fuse.P2", "esc.VIN"], "volts": 7.4, "gauge_awg": 16, "length_mm": 80.0 },
    { "id": "v5", "pins": ["esc.BEC5V", "mcu.5V", "lifter.+"], "volts": 5.0 },
    { "id": "gnd", "pins": ["batt.-", "esc.GND", "mcu.GND", "lifter.-"] },
    { "id": "m1_a", "pins": ["esc.M1+", "m1.M+"], "gauge_awg": 18, "length_mm": 70.0 },
    { "id": "m1_b", "pins": ["esc.M1-", "m1.M-"], "gauge_awg": 18, "length_mm": 70.0 },
    { "id": "pwm_l", "pins": ["mcu.GP2", "esc.S1"], "signal": "pwm" },
    { "id": "servo_sig", "pins": ["mcu.GP3", "lifter.SIG"], "signal": "pwm" },
    { "id": "s2_unused", "pins": ["esc.S2"], "signal": "pwm" }
  ],
  "buses": [],
  "failsafe": null
}
